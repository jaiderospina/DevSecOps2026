# ============================================================
# SecureVault — Variables de entorno de producción
# Generado por Ansible — NO editar manualmente en producción
# Fecha: {{ ansible_date_time.iso8601 }}
# ============================================================

# ── Base de datos ──────────────────────────────────────────
DATABASE_URL=postgresql://securevault:{{ db_password | default('CHANGE_ME') }}@postgres:5432/securevault

# ── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_URL=amqp://svuser:{{ rmq_password | default('CHANGE_ME') }}@rabbitmq:5672/

# ── Seguridad JWT ──────────────────────────────────────────
SECRET_KEY={{ secret_key | default('CHANGE_ME_VERY_LONG_SECRET_KEY') }}

# ── Cifrado de secretos (Fernet AES-128) ──────────────────
FERNET_KEY={{ fernet_key | default('CHANGE_ME_FERNET_KEY') }}

# ── Modo de ejecución ──────────────────────────────────────
DEBUG=false

# ── Imágenes Docker ────────────────────────────────────────
DOCKER_REGISTRY={{ docker_registry | default('securevault') }}
IMAGE_TAG={{ image_tag | default('latest') }}

# ── Worker ─────────────────────────────────────────────────
SECRET_ROTATION_DAYS=90
CHECK_INTERVAL_SECONDS=30

# ── Admin por defecto (solo primer arranque) ───────────────
ALLOW_SELF_REGISTER_ADMIN=false
ADMIN_USERNAME={{ admin_username | default('admin') }}
ADMIN_EMAIL={{ admin_email | default('admin@securevault.local') }}
ADMIN_PASSWORD={{ admin_password | default('CHANGE_ME_ADMIN_PASS') }}

