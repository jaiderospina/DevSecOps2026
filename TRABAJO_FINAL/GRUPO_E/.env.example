# Copiar a .env y ajustar valores. No commitear .env.

# PostgreSQL
POSTGRES_USER=vulncentral
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=vulncentral
POSTGRES_PORT=5432
# Host desde tu máquina (Alembic / app fuera de Docker). En compose, los servicios usan el hostname del servicio.
POSTGRES_HOST=localhost
# Opcional: si está definida, tiene prioridad sobre POSTGRES_* al construir la URL SQLAlchemy.
# DATABASE_URL=postgresql+psycopg://vulncentral:change_me_in_production@localhost:5432/vulncentral

# pgAdmin (solo desarrollo; desactivado al usar docker-compose.prod.yml)
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_in_production

# RabbitMQ
RABBITMQ_DEFAULT_USER=vulncentral
RABBITMQ_DEFAULT_PASS=change_me_in_production
RABBITMQ_DEFAULT_VHOST=vulncentral
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# API Gateway (FastAPI)
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
# Orígenes CORS separados por coma (esquema + host + puerto, sin barra final). DEBE incluir el origen exacto del SPA en el navegador; si falta, el navegador muestra «Failed to fetch» al llamar al API. Ver docs/diagnostico-ingesta-trivy-carga.md sección 5.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:80,http://127.0.0.1:80,http://localhost:5173

# Celery — credenciales y vhost deben coincidir con RABBITMQ_* arriba.
CELERY_BROKER_URL=amqp://vulncentral:change_me_in_production@rabbitmq:5672/vulncentral
# rpc:// usa el mismo broker para resultados (adecuado para desarrollo).
CELERY_RESULT_BACKEND=rpc://

# JWT (Fase 3 — obligatorio para login y rutas protegidas)
JWT_SECRET=change_me_use_long_random_string_in_production
JWT_ALGORITHM=HS256
# Duración del access token en minutos (por defecto en código: 30 si se omite)
JWT_EXPIRE_MINUTES=30

# Fase 8 — Rate limiting (slowapi; principalmente POST /auth/login)
# RATE_LIMIT_ENABLED=false desactiva el limitador.
RATE_LIMIT_ENABLED=true
# Formato slowapi, p. ej. 5/minute. 0/off/none desactiva el límite de login (solo desarrollo).
RATE_LIMIT_LOGIN=5/minute

# Tamaño máximo del cuerpo JSON para POST .../scans/{id}/trivy-report (bytes). Si se omite: 10 MiB.
MAX_JSON_BODY_BYTES=10485760

# Informes Trivy (Fase 5): API escribe en REPORTS_DIR; el worker solo acepta rutas bajo REPORTS_BASE_DIR (volumen compartido en compose: /app/data/reports).
# REPORTS_DIR=/app/data/reports
# REPORTS_BASE_DIR=/app/data/reports

# Frontend — puerto publicado en el host (nginx del contenedor sigue en 80 dentro de la red Docker)
FRONTEND_PORT=8080

# URL del API tal como la resuelve el NAVEGADOR (no uses hostnames solo Docker, p. ej. http://api-gateway:8000).
# En docker compose: el servicio frontend recibe VC_API_BASE_URL desde este valor y genera /config.json en runtime (sin rebuild).
# En vite dev / build local: sigue siendo VITE_API_BASE_URL (fallback si no hay config.json).
VITE_API_BASE_URL=http://localhost:8000

# docker-compose.hub.yml — tag compartido de imágenes maurobaquero/vulncentral-* en Docker Hub (si se omite, el compose usa v1.0.0)
# VULNCENTRAL_TAG=v1.0.0
